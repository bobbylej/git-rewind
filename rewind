#!/usr/bin/env bash
#
# rewind — jump back to a recently used git branch
#
# Usage: rewind [--time DURATION]
#        rewind --config [--global] NAME [VALUE]
#
# Setup (bash + zsh):
#   ./install.sh
#
# Override the default timeframe from your shell:
#   export REWIND_DEFAULT_TIMEFRAME="3 days"
#
# Or persist defaults in git config (like git itself):
#   rewind --config timeframe "3 days"
#   rewind --config --global timeframe "1 week"
#

set -euo pipefail

CONFIG_SECTION="rewind"
BUILTIN_DEFAULT_TIMEFRAME="1 day"

# --- colors (disabled when stdout is not a TTY) ---
if [[ -t 1 ]]; then
  BOLD='\033[1m'
  DIM='\033[2m'
  GREEN='\033[32m'
  RESET='\033[0m'
  REVERSE='\033[7m'
else
  BOLD='' DIM='' GREEN='' RESET='' REVERSE=''
fi

usage() {
  cat <<EOF
Usage: rewind [--time DURATION]
       rewind --config [--global|--system] [--unset] NAME [VALUE]

Switch to a recently used branch using an interactive list.

Options:
  --time DURATION   Look back this far for this run only
                    Examples: "4 hours", "1 day", "2 weeks", "30m", "1w"
  --config NAME [VALUE]
                    Read or write a default (stored as git config ${CONFIG_SECTION}.*)
    --global        Write to ~/.gitconfig instead of the local repo
    --system        Write to system-wide git config
    --unset         Remove the stored default

Configurable parameters:
  timeframe         Default lookback duration (default: ${BUILTIN_DEFAULT_TIMEFRAME})

Default precedence: --time > REWIND_DEFAULT_TIMEFRAME > git config > built-in default

Examples:
  rewind --config timeframe "3 days"
  rewind --config --global timeframe "1 week"
  rewind --config timeframe              # print current value

Environment:
  REWIND_DEFAULT_TIMEFRAME   Override the default duration (e.g. "3 days")

Setup:
  ./install.sh               Install for bash and zsh (~/.local/bin + completions)

Keys:
  ↑ / ↓   Navigate
  Enter   Checkout selected branch
  Esc     Cancel
EOF
}

die() {
  echo "rewind: $*" >&2
  exit 1
}

require_git_repo() {
  git rev-parse --git-dir >/dev/null 2>&1 || die "not inside a git repository"
}

config_full_key() {
  echo "${CONFIG_SECTION}.${1}"
}

known_config_param() {
  case "$1" in
    timeframe) return 0 ;;
    *) return 1 ;;
  esac
}

get_git_config() {
  local param="$1"
  git config --get "$(config_full_key "$param")" 2>/dev/null || true
}

validate_config_value() {
  local param="$1"
  local value="$2"

  case "$param" in
    timeframe)
      parse_duration_to_cutoff "$value" >/dev/null
      ;;
  esac
}

resolve_default_timeframe() {
  if [[ -n "${REWIND_DEFAULT_TIMEFRAME:-}" ]]; then
    echo "$REWIND_DEFAULT_TIMEFRAME"
    return 0
  fi

  local from_config
  from_config="$(get_git_config timeframe)"
  if [[ -n "$from_config" ]]; then
    echo "$from_config"
    return 0
  fi

  echo "$BUILTIN_DEFAULT_TIMEFRAME"
}

handle_config_command() {
  local scope="" unset=false param value git_args=()

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --global) scope="global"; shift ;;
      --system) scope="system"; shift ;;
      --unset) unset=true; shift ;;
      -*) die "unknown --config option: $1" ;;
      *) break ;;
    esac
  done

  [[ $# -ge 1 ]] || die "--config requires a parameter name (try --help)"
  param="$1"
  shift

  known_config_param "$param" || die "unknown config parameter: '$param' (known: timeframe)"

  case "$scope" in
    global) git_args=(--global) ;;
    system) git_args=(--system) ;;
    *) require_git_repo ;;
  esac

  local key
  key="$(config_full_key "$param")"

  if $unset; then
    git config "${git_args[@]}" --unset "$key" 2>/dev/null || true
    exit 0
  fi

  if [[ $# -eq 0 ]]; then
    value="$(get_git_config "$param")"
    [[ -n "$value" ]] || die "config parameter '${param}' is not set"
    printf '%s\n' "$value"
    exit 0
  fi

  value="$1"
  validate_config_value "$param" "$value"
  git config "${git_args[@]}" "$key" "$value"
  exit 0
}

# Parse human-friendly durations into a cutoff unix timestamp.
# Supports: "N unit", or shorthand like 30m, 4h, 2d, 1w.
parse_duration_to_cutoff() {
  local input="$1"
  local normalized amount unit seconds_per

  normalized="$(echo "$input" | tr '[:upper:]' '[:lower:]' | xargs)"
  [[ -n "$normalized" ]] || die "empty time duration"

  if [[ "$normalized" =~ ^([0-9]+)([mhdw]|min|mins|minute|minutes|hour|hours|day|days|week|weeks|month|months)$ ]]; then
    amount="${BASH_REMATCH[1]}"
    unit="${BASH_REMATCH[2]}"
  elif [[ "$normalized" =~ ^([0-9]+)[[:space:]]+(minute|minutes|min|mins|hour|hours|day|days|week|weeks|month|months)$ ]]; then
    amount="${BASH_REMATCH[1]}"
    unit="${BASH_REMATCH[2]}"
  else
    die "invalid time duration: '$input' (examples: '1 day', '4 hours', '2w', '30m')"
  fi

  case "$unit" in
    m|min|mins|minute|minutes) seconds_per=60 ;;
    h|hour|hours)              seconds_per=3600 ;;
    d|day|days)                seconds_per=86400 ;;
    w|week|weeks)              seconds_per=604800 ;;
    month|months)                seconds_per=2592000 ;; # 30 days
    *) die "unsupported time unit in: '$input'" ;;
  esac

  echo $(( $(date +%s) - amount * seconds_per ))
}

parse_checkout_reflog_line() {
  local line="$1"

  if [[ "$line" =~ ^[0-9a-f]+\ HEAD@\{([0-9]+)\}:\ checkout:\ moving\ from\ .+\ to\ (.+)$ ]]; then
    CHECKOUT_TS="${BASH_REMATCH[1]}"
    CHECKOUT_BRANCH="${BASH_REMATCH[2]}"
    return 0
  fi

  if [[ "$line" =~ ^[0-9a-f]+\ HEAD@\{([0-9]+)\}:\ switch:\ from\ .+\ to\ (.+)$ ]]; then
    CHECKOUT_TS="${BASH_REMATCH[1]}"
    CHECKOUT_BRANCH="${BASH_REMATCH[2]}"
    return 0
  fi

  return 1
}

branch_exists() {
  git show-ref --verify --quiet "refs/heads/${1}" 2>/dev/null
}

# Collect branches with checkout sessions overlapping the time window.
# A branch checked out before the window but still active counts as recent
# because its session ends at "now".
collect_recent_branches() {
  local cutoff="$1"
  local -a co_branch=() co_ts=()
  local line now prev_ts
  local -a sess_branch=() sess_end=()
  local -a result_branch=() result_end=()
  local i j

  while IFS= read -r line; do
    if parse_checkout_reflog_line "$line"; then
      co_branch+=("$CHECKOUT_BRANCH")
      co_ts+=("$CHECKOUT_TS")
    fi
  done < <(git reflog --date=unix HEAD 2>/dev/null)

  if ((${#co_branch[@]} == 0)); then
    return 1
  fi

  now="$(date +%s)"
  prev_ts=""

  for (( i=0; i<${#co_branch[@]}; i++ )); do
    if [[ -n "$prev_ts" ]]; then
      sess_branch+=("${co_branch[$i]}")
      sess_end+=("$prev_ts")
    fi
    prev_ts="${co_ts[$i]}"
  done

  sess_branch+=("${co_branch[0]}")
  sess_end+=("$now")

  for (( i=0; i<${#sess_branch[@]}; i++ )); do
    (( sess_end[i] >= cutoff )) || continue
    branch_exists "${sess_branch[$i]}" || continue

    for (( j=0; j<${#result_branch[@]}; j++ )); do
      if [[ "${result_branch[$j]}" == "${sess_branch[$i]}" ]]; then
        if (( sess_end[i] > result_end[j] )); then
          result_end[$j]="${sess_end[$i]}"
        fi
        continue 2
      fi
    done

    result_branch+=("${sess_branch[$i]}")
    result_end+=("${sess_end[$i]}")
  done

  if ((${#result_branch[@]} == 0)); then
    return 1
  fi

  for (( i=0; i<${#result_branch[@]}; i++ )); do
    printf '%010d %s\n' "${result_end[$i]}" "${result_branch[$i]}"
  done | sort -rn | cut -d' ' -f2-
}

INTERACTIVE_IN=""
INTERACTIVE_OUT=""
MENU_DRAWN=false

menu_cols() {
  local cols
  cols="$(tput cols 2>/dev/null || true)"
  if [[ -n "$cols" && "$cols" -gt 0 ]]; then
    echo "$cols"
  else
    echo "${COLUMNS:-80}"
  fi
}

clip_branch_name() {
  local branch="$1"
  local max="${2:-78}"

  if ((${#branch} > max)); then
    echo "${branch:0:$(( max - 3 ))}..."
  else
    echo "$branch"
  fi
}

setup_interactive_terminal() {
  # Always prefer /dev/tty so alt-screen, redraw, and cleanup use one stream.
  if [[ -e /dev/tty ]] && { true >/dev/tty; } 2>/dev/null; then
    INTERACTIVE_IN=/dev/tty
    INTERACTIVE_OUT=/dev/tty
    return 0
  fi

  if [[ -t 0 && -t 1 ]]; then
    INTERACTIVE_IN=/dev/stdin
    INTERACTIVE_OUT=/dev/stdout
    return 0
  fi

  die "interactive mode requires a terminal"
}

interactive_stty_mode() {
  stty -echo -icanon min 1 time 0 <"$INTERACTIVE_IN" 2>/dev/null || true
}

interactive_stty_drain() {
  stty -echo -icanon min 0 time 0 <"$INTERACTIVE_IN" 2>/dev/null || true
}

read_esc_continuation() {
  local seq="" byte=""

  if [[ "${BASH_VERSINFO[0]:-0}" -ge 4 ]]; then
    if IFS= read -rsn1 -t 0.02 byte <"$INTERACTIVE_IN" 2>/dev/null && [[ -n "$byte" ]]; then
      seq="$byte"
      if [[ "$byte" == '[' || "$byte" == 'O' ]]; then
        IFS= read -rsn1 -t 0.02 byte <"$INTERACTIVE_IN" 2>/dev/null && [[ -n "$byte" ]] && seq+="$byte"
      fi
    fi
    printf '%s' "$seq"
    return 0
  fi

  # Bash 3.2 (macOS default): brief pause, then drain without blocking per byte.
  sleep 0.01
  interactive_stty_drain
  while IFS= read -rsn1 byte <"$INTERACTIVE_IN" 2>/dev/null && [[ -n "$byte" ]]; do
    seq+="$byte"
    if [[ ${#seq} -ge 2 && "$seq" == "["* ]]; then
      break
    fi
    if [[ ${#seq} -ge 2 && "$seq" == O* ]]; then
      break
    fi
    [[ ${#seq} -ge 6 ]] && break
  done
  printf '%s' "$seq"
}

read_interactive_key() {
  local key="" seq=""

  IFS= read -rsn1 key <"$INTERACTIVE_IN" || return 1

  if [[ "$key" != $'\x1b' ]]; then
    READ_KEY="$key"
    return 0
  fi

  seq="$(read_esc_continuation)"
  interactive_stty_mode
  READ_KEY="${key}${seq}"
  return 0
}

format_branch_label() {
  local branch="$1"
  local current="$2"
  local display width

  width=$(( $(menu_cols) - 2 ))
  display="$(clip_branch_name "$branch" "$width")"

  if [[ "$branch" == "$current" ]]; then
    printf '%b● %s%b' "$GREEN" "$display" "$RESET"
  else
    printf '  %s' "$display"
  fi
}

print_menu_line() {
  local selected="$1"
  local index="$2"
  local current_branch="$3"
  local branch="$4"

  if (( index == selected )); then
    printf '\033[K%b%s%b\n' "$REVERSE" "$(format_branch_label "$branch" "$current_branch")" "$RESET"
  else
    printf '\033[K%s\n' "$(format_branch_label "$branch" "$current_branch")"
  fi
}

draw_menu() {
  local selected="$1"
  local current_branch="$2"
  shift 2
  local -a branches=("$@")
  local count="${#branches[@]}"
  local block_lines=$(( count + 4 ))
  local i=0

  {
    if $MENU_DRAWN; then
      printf '\033[%dA' "$block_lines"
    else
      printf '\033[2J\033[H'
      MENU_DRAWN=true
    fi

    printf '\033[K%bRecent branches%b  %b(%d)%b\n' "$BOLD" "$RESET" "$DIM" "$count" "$RESET"
    printf '\033[K\n'

    for branch in "${branches[@]}"; do
      print_menu_line "$selected" "$i" "$current_branch" "$branch"
      ((i++)) || true
    done

    printf '\033[K\n'
    printf '\033[K%b↑/↓%b navigate  %bEnter%b select  %bEsc%b cancel\n' \
      "$DIM" "$RESET" "$DIM" "$RESET" "$DIM" "$RESET"
  } >"$INTERACTIVE_OUT"
}

# Interactive arrow-key selector. Sets REWIND_CHOICE on success, returns 1 on cancel.
interactive_select() {
  local current_branch="$1"
  shift
  local -a branches=("$@")
  local count="${#branches[@]}"
  local selected=0

  REWIND_CHOICE=""
  MENU_DRAWN=false
  setup_interactive_terminal

  local saved_stty=""
  saved_stty="$(stty -g <"$INTERACTIVE_IN" 2>/dev/null || true)"

  cleanup_interactive() {
    printf '\033[?1049l' >"$INTERACTIVE_OUT" 2>/dev/null || true
    [[ -n "$saved_stty" ]] && stty "$saved_stty" <"$INTERACTIVE_IN" 2>/dev/null || true
    tput cnorm >"$INTERACTIVE_OUT" 2>/dev/null || true
    MENU_DRAWN=false
  }

  finish_interactive() {
    trap - EXIT
    cleanup_interactive
  }

  tput civis >"$INTERACTIVE_OUT" 2>/dev/null || true
  trap cleanup_interactive EXIT
  interactive_stty_mode
  printf '\033[?1049h\033[2J\033[H' >"$INTERACTIVE_OUT" 2>/dev/null || true

  draw_menu "$selected" "$current_branch" "${branches[@]}"

  while true; do
    read_interactive_key || return 1

    case "$READ_KEY" in
      $'\x1b[A'|$'\x1bOA')
        if (( selected > 0 )); then
          ((selected--))
          draw_menu "$selected" "$current_branch" "${branches[@]}"
        fi
        ;;
      $'\x1b[B'|$'\x1bOB')
        if (( selected < count - 1 )); then
          ((selected++))
          draw_menu "$selected" "$current_branch" "${branches[@]}"
        fi
        ;;
      ''|$'\n'|$'\r')
        REWIND_CHOICE="${branches[$selected]}"
        finish_interactive
        return 0
        ;;
      q|Q|$'\x1b'*)
        finish_interactive
        return 1
        ;;
    esac
  done
}

main() {
  local timeframe=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --time)
        [[ $# -ge 2 ]] || die "--time requires a value"
        timeframe="$2"
        shift 2
        ;;
      --config)
        shift
        handle_config_command "$@"
        ;;
      -h|--help)
        usage
        exit 0
        ;;
      *)
        die "unknown argument: $1 (try --help)"
        ;;
    esac
  done

  require_git_repo

  if [[ -z "$timeframe" ]]; then
    timeframe="$(resolve_default_timeframe)"
  fi

  local cutoff
  cutoff="$(parse_duration_to_cutoff "$timeframe")"

  local -a branches=()
  while IFS= read -r branch; do
    branches+=("$branch")
  done < <(collect_recent_branches "$cutoff" || true)

  if ((${#branches[@]} == 0)); then
    die "no branches found in the last ${timeframe}"
  fi

  local current_branch
  current_branch="$(git branch --show-current 2>/dev/null || echo "")"

  if ! interactive_select "$current_branch" "${branches[@]}"; then
    exit 0
  fi

  local choice="$REWIND_CHOICE"

  if [[ "$choice" == "$current_branch" ]]; then
    exit 0
  fi

  echo "Switching to '${choice}'..."
  git checkout "$choice"
}

main "$@"
