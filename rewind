#!/usr/bin/env bash
#
# rewind — jump back to a recently used git branch
#
# Usage: rewind [--time DURATION]
#        rewind --config [--global] NAME [VALUE]
#
# Setup (bash + zsh):
#   ./install.sh
#
# Override the default timeframe from your shell:
#   export REWIND_DEFAULT_TIMEFRAME="3 days"
#
# Or persist defaults in git config (like git itself):
#   rewind --config timeframe "3 days"
#   rewind --config --global timeframe "1 week"
#

set -euo pipefail

CONFIG_SECTION="rewind"
BUILTIN_DEFAULT_TIMEFRAME="1 day"

# --- colors (disabled when stdout is not a TTY) ---
if [[ -t 1 ]]; then
  BOLD='\033[1m'
  DIM='\033[2m'
  GREEN='\033[32m'
  RESET='\033[0m'
  REVERSE='\033[7m'
else
  BOLD='' DIM='' GREEN='' RESET='' REVERSE=''
fi

usage() {
  cat <<EOF
Usage: rewind [--time DURATION]
       rewind --config [--global|--system] [--unset] NAME [VALUE]

Switch to a recently used branch using an interactive list.

Options:
  --time DURATION   Look back this far for this run only
                    Examples: "4 hours", "1 day", "2 weeks", "30m", "1w"
  --config NAME [VALUE]
                    Read or write a default (stored as git config ${CONFIG_SECTION}.*)
    --global        Write to ~/.gitconfig instead of the local repo
    --system        Write to system-wide git config
    --unset         Remove the stored default

Configurable parameters:
  timeframe         Default lookback duration (default: ${BUILTIN_DEFAULT_TIMEFRAME})

Default precedence: --time > REWIND_DEFAULT_TIMEFRAME > git config > built-in default

Examples:
  rewind --config timeframe "3 days"
  rewind --config --global timeframe "1 week"
  rewind --config timeframe              # print current value

Environment:
  REWIND_DEFAULT_TIMEFRAME   Override the default duration (e.g. "3 days")

Setup:
  ./install.sh               Install for bash and zsh (~/.local/bin + completions)

Keys:
  ↑ / ↓   Navigate
  Enter   Checkout selected branch
  Esc     Cancel
EOF
}

die() {
  echo "rewind: $*" >&2
  exit 1
}

require_git_repo() {
  git rev-parse --git-dir >/dev/null 2>&1 || die "not inside a git repository"
}

config_full_key() {
  echo "${CONFIG_SECTION}.${1}"
}

known_config_param() {
  case "$1" in
    timeframe) return 0 ;;
    *) return 1 ;;
  esac
}

get_git_config() {
  local param="$1"
  git config --get "$(config_full_key "$param")" 2>/dev/null || true
}

validate_config_value() {
  local param="$1"
  local value="$2"

  case "$param" in
    timeframe)
      parse_duration_to_cutoff "$value" >/dev/null
      ;;
  esac
}

resolve_default_timeframe() {
  if [[ -n "${REWIND_DEFAULT_TIMEFRAME:-}" ]]; then
    echo "$REWIND_DEFAULT_TIMEFRAME"
    return 0
  fi

  local from_config
  from_config="$(get_git_config timeframe)"
  if [[ -n "$from_config" ]]; then
    echo "$from_config"
    return 0
  fi

  echo "$BUILTIN_DEFAULT_TIMEFRAME"
}

handle_config_command() {
  local scope="" unset=false param value git_args=()

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --global) scope="global"; shift ;;
      --system) scope="system"; shift ;;
      --unset) unset=true; shift ;;
      -*) die "unknown --config option: $1" ;;
      *) break ;;
    esac
  done

  [[ $# -ge 1 ]] || die "--config requires a parameter name (try --help)"
  param="$1"
  shift

  known_config_param "$param" || die "unknown config parameter: '$param' (known: timeframe)"

  case "$scope" in
    global) git_args=(--global) ;;
    system) git_args=(--system) ;;
    *) require_git_repo ;;
  esac

  local key
  key="$(config_full_key "$param")"

  if $unset; then
    git config "${git_args[@]}" --unset "$key" 2>/dev/null || true
    exit 0
  fi

  if [[ $# -eq 0 ]]; then
    value="$(get_git_config "$param")"
    [[ -n "$value" ]] || die "config parameter '${param}' is not set"
    printf '%s\n' "$value"
    exit 0
  fi

  value="$1"
  validate_config_value "$param" "$value"
  git config "${git_args[@]}" "$key" "$value"
  exit 0
}

# Parse human-friendly durations into a cutoff unix timestamp.
# Supports: "N unit", or shorthand like 30m, 4h, 2d, 1w.
parse_duration_to_cutoff() {
  local input="$1"
  local normalized amount unit seconds_per

  normalized="$(echo "$input" | tr '[:upper:]' '[:lower:]' | xargs)"
  [[ -n "$normalized" ]] || die "empty time duration"

  if [[ "$normalized" =~ ^([0-9]+)([mhdw]|min|mins|minute|minutes|hour|hours|day|days|week|weeks|month|months)$ ]]; then
    amount="${BASH_REMATCH[1]}"
    unit="${BASH_REMATCH[2]}"
  elif [[ "$normalized" =~ ^([0-9]+)[[:space:]]+(minute|minutes|min|mins|hour|hours|day|days|week|weeks|month|months)$ ]]; then
    amount="${BASH_REMATCH[1]}"
    unit="${BASH_REMATCH[2]}"
  else
    die "invalid time duration: '$input' (examples: '1 day', '4 hours', '2w', '30m')"
  fi

  case "$unit" in
    m|min|mins|minute|minutes) seconds_per=60 ;;
    h|hour|hours)              seconds_per=3600 ;;
    d|day|days)                seconds_per=86400 ;;
    w|week|weeks)              seconds_per=604800 ;;
    month|months)                seconds_per=2592000 ;; # 30 days
    *) die "unsupported time unit in: '$input'" ;;
  esac

  echo $(( $(date +%s) - amount * seconds_per ))
}

branch_from_reflog_message() {
  local message="$1"
  local branch=""

  if [[ "$message" =~ checkout:\ moving\ from\ .+\ to\ (.+)$ ]]; then
    branch="${BASH_REMATCH[1]}"
  elif [[ "$message" =~ (checkout|switch):\ moving\ to\ (.+)$ ]]; then
    branch="${BASH_REMATCH[2]}"
  elif [[ "$message" =~ switch:\ from\ .+\ to\ (.+)$ ]]; then
    branch="${BASH_REMATCH[1]}"
  fi

  if [[ -n "$branch" ]]; then
    echo "$branch"
    return 0
  fi

  return 1
}

# Collect unique branch names from reflog, most recent first.
collect_recent_branches() {
  local cutoff="$1"
  local -a seen=()
  local -a branches=()
  local timestamp message branch idx

  idx=0
  while IFS= read -r line; do
    timestamp="${line%% *}"
    message="${line#* }"

    if (( timestamp < cutoff )); then
      break
    fi

    branch=""
    if ! branch="$(branch_from_reflog_message "$message")"; then
      branch="$(git rev-parse --abbrev-ref "HEAD@{${idx}}" 2>/dev/null || true)"
    fi
    ((idx++)) || true

    [[ -n "$branch" && "$branch" != "HEAD" && "$branch" != "(no branch)" ]] || continue
    git show-ref --verify --quiet "refs/heads/${branch}" 2>/dev/null || continue

    local known=false
    for existing in "${seen[@]}"; do
      if [[ "$existing" == "$branch" ]]; then
        known=true
        break
      fi
    done
    $known && continue

    seen+=("$branch")
    branches+=("$branch")
  done < <(git reflog --date=unix --format='%ct %gs' HEAD 2>/dev/null)

  if ((${#branches[@]} == 0)); then
    return 1
  fi

  printf '%s\n' "${branches[@]}"
}

format_branch_label() {
  local branch="$1"
  local current="$2"

  if [[ "$branch" == "$current" ]]; then
    printf '%b● %s' "$GREEN" "$branch"
  else
    printf '  %s' "$branch"
  fi
}

draw_menu() {
  local selected="$1"
  local current_branch="$2"
  shift 2
  local -a branches=("$@")
  local count="${#branches[@]}"
  local i=0

  printf '\033[2J\033[H'
  printf '%bRecent branches%b  %b(%d)%b\n\n' "$BOLD" "$RESET" "$DIM" "$count" "$RESET"

  for branch in "${branches[@]}"; do
    if (( i == selected )); then
      printf ' %b %b\n' "$REVERSE" "$(format_branch_label "$branch" "$current_branch")$RESET"
    else
      printf '  %b\n' "$(format_branch_label "$branch" "$current_branch")"
    fi
    ((i++)) || true
  done

  printf '\n%b↑/↓%b navigate  %bEnter%b select  %bEsc%b cancel\n' \
    "$DIM" "$RESET" "$DIM" "$RESET" "$DIM" "$RESET"
}

# Interactive arrow-key selector. Prints selected branch to stdout, or exits 1 on cancel.
interactive_select() {
  local current_branch="$1"
  shift
  local -a branches=("$@")
  local count="${#branches[@]}"
  local selected=0

  [[ -t 0 && -t 1 ]] || die "interactive mode requires a terminal"

  tput civis 2>/dev/null || true
  trap 'tput cnorm 2>/dev/null || true' EXIT

  draw_menu "$selected" "$current_branch" "${branches[@]}"

  while true; do
    local key key2=""
    IFS= read -rsn1 key || exit 1

    case "$key" in
      $'\x1b')
        IFS= read -rsn2 -t 0 key2 || key2=""
        case "$key2" in
          '[A') (( selected > 0 )) && ((selected--)) && draw_menu "$selected" "$current_branch" "${branches[@]}" ;;
          '[B') (( selected < count - 1 )) && ((selected++)) && draw_menu "$selected" "$current_branch" "${branches[@]}" ;;
          '') exit 1 ;;
        esac
        ;;
      '')
        tput cnorm 2>/dev/null || true
        trap - EXIT
        printf '%s' "${branches[$selected]}"
        return 0
        ;;
      q|Q) exit 1 ;;
    esac
  done
}

main() {
  local timeframe=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --time)
        [[ $# -ge 2 ]] || die "--time requires a value"
        timeframe="$2"
        shift 2
        ;;
      --config)
        shift
        handle_config_command "$@"
        ;;
      -h|--help)
        usage
        exit 0
        ;;
      *)
        die "unknown argument: $1 (try --help)"
        ;;
    esac
  done

  require_git_repo

  if [[ -z "$timeframe" ]]; then
    timeframe="$(resolve_default_timeframe)"
  fi

  local cutoff
  cutoff="$(parse_duration_to_cutoff "$timeframe")"

  local -a branches=()
  while IFS= read -r branch; do
    branches+=("$branch")
  done < <(collect_recent_branches "$cutoff" || true)

  if ((${#branches[@]} == 0)); then
    die "no branches found in the last ${timeframe}"
  fi

  local current_branch
  current_branch="$(git branch --show-current 2>/dev/null || echo "")"

  local choice
  choice="$(interactive_select "$current_branch" "${branches[@]}")"

  if [[ "$choice" == "$current_branch" ]]; then
    echo "Already on '${choice}'."
    exit 0
  fi

  echo "Switching to '${choice}'..."
  git checkout "$choice"
}

main "$@"
